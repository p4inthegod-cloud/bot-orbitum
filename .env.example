# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Get from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxyz

# Your deployed app URL (no trailing slash) — used to set webhook in production
# Example: https://trading-funnel-bot.vercel.app
TELEGRAM_WEBHOOK_URL=https://YOUR_APP_URL

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── Auth ────────────────────────────────────────────────────────────────────
# Any random string (32+ chars) — used to sign JWT session cookies
JWT_SECRET=change-this-to-a-long-random-secret-string-here

# Admin login password for the web panel
ADMIN_SECRET=your-admin-password-here

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
VITE_APP_ID=trading-funnel-bot
